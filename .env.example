# Compose project name — keeps dev and e2e environments isolated
COMPOSE_PROJECT_NAME=madm_dev

# Host ports (mapped into the container on overlay compose files)
WEB_PORT=3000
API_PORT=8000
WORKER_PORT=8001
TOOLS_PORT=8002
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=madm

# Service URLs (used by containers — hostname = service name)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/madm
REDIS_URL=redis://redis:6379/0

# Agent work directory (mounted into worker container)
AGENT_WORK_PARENT=/agent-work

# MCP tools gateway URL (used by worker)
TOOLS_GATEWAY_URL=http://tools:8002
