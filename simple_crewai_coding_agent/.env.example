# LLM Configuration for simple_crewai_coding_agent
#
# Copy this file to .env and edit as needed.
# The agent defaults to Ollama — make sure Ollama is running and the model is pulled:
#   ollama pull qwen2.5-coder:7b

# Provider: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Model name (without provider prefix)
LLM_MODEL=qwen2.5-coder:7b

# Ollama server endpoint (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Sampling temperature — lower = more deterministic code output
LLM_TEMPERATURE=0.2

# Required by CrewAI even when not using OpenAI — leave as "NA" for Ollama
# Set to your real key when LLM_PROVIDER=openai
OPENAI_API_KEY=NA
