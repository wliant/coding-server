{
  "openapi": "3.1.0",
  "info": {
    "title": "Multi-Agent Software Development System API",
    "version": "0.5.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/agents": {
      "get": {
        "summary": "List Agents",
        "operationId": "listAgents",
        "tags": [
          "agents"
        ],
        "description": "Returns all active agents from the agent registry, ordered by display_name.",
        "responses": {
          "200": {
            "description": "List of active agents",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AgentResponse"
                  },
                  "type": "array",
                  "title": "Response List Agents"
                }
              }
            }
          }
        }
      }
    },
    "/projects": {
      "get": {
        "summary": "List Projects",
        "operationId": "list_projects_projects_get",
        "tags": [
          "projects"
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ProjectSummary"
                  },
                  "type": "array",
                  "title": "Response List Projects Projects Get"
                }
              }
            }
          }
        }
      }
    },
    "/tasks": {
      "get": {
        "summary": "List Tasks",
        "operationId": "list_tasks_tasks_get",
        "tags": [
          "tasks"
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/TaskResponse"
                  },
                  "type": "array",
                  "title": "Response List Tasks Tasks Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Task",
        "operationId": "create_task_tasks_post",
        "tags": [
          "tasks"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task_id}": {
      "get": {
        "summary": "Get Task Detail",
        "operationId": "getTaskDetail",
        "tags": [
          "tasks"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Task Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskDetailResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update Task",
        "operationId": "update_task_tasks__task_id__patch",
        "tags": [
          "tasks"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task_id}/push": {
      "post": {
        "summary": "Push Task To Remote",
        "operationId": "pushTaskToRemote",
        "tags": [
          "tasks"
        ],
        "description": "Pushes the task's work directory to a remote git repository. If git_url is provided in the body, it is saved to the project record before the push.",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Task Id"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/PushTaskRequest"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Body"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Push succeeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PushResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Task is not in Completed status; push not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Project has no git_url configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Git push to remote failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/settings": {
      "get": {
        "summary": "Get Settings",
        "operationId": "get_settings_settings_get",
        "tags": [
          "settings"
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SettingsResponse"
                }
              }
            }
          }
        },
        "description": "Return all settings with defaults for any unset key. Valid keys: agent.work.path, agent.simple_crewai.llm_provider (ollama|openai|anthropic), agent.simple_crewai.llm_model, agent.simple_crewai.llm_temperature (float 0.0-2.0), agent.simple_crewai.ollama_base_url, agent.simple_crewai.openai_api_key, agent.simple_crewai.anthropic_api_key, github.token"
      },
      "put": {
        "summary": "Update Settings",
        "operationId": "update_settings_settings_put",
        "tags": [
          "settings"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSettingsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SettingsResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "description": "Partial update: only supply keys to change. Unknown keys return 422. Valid keys: agent.work.path, agent.simple_crewai.llm_provider (ollama|openai|anthropic), agent.simple_crewai.llm_model, agent.simple_crewai.llm_temperature (float 0.0-2.0), agent.simple_crewai.ollama_base_url, agent.simple_crewai.openai_api_key, agent.simple_crewai.anthropic_api_key, github.token"
      }
    }
  },
  "components": {
    "schemas": {
      "AgentSummary": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "identifier": {
            "type": "string",
            "title": "Identifier",
            "description": "Machine-readable key; maps to the agent library"
          },
          "display_name": {
            "type": "string",
            "title": "Display Name",
            "description": "Human-readable name shown in the UI"
          }
        },
        "type": "object",
        "required": [
          "id",
          "identifier",
          "display_name"
        ],
        "title": "AgentSummary"
      },
      "AgentResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "identifier": {
            "type": "string",
            "title": "Identifier"
          },
          "display_name": {
            "type": "string",
            "title": "Display Name"
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "identifier",
          "display_name",
          "is_active",
          "created_at"
        ],
        "title": "AgentResponse"
      },
      "PushTaskRequest": {
        "properties": {
          "git_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Git Url",
            "description": "Git repository URL to save to the project and push to. If provided, saved to project before push."
          }
        },
        "type": "object",
        "title": "PushTaskRequest"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "components": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "title": "Components"
          }
        },
        "type": "object",
        "required": [
          "status",
          "components"
        ],
        "title": "HealthResponse"
      },
      "ProjectSummary": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          },
          "source_type": {
            "type": "string",
            "title": "Source Type"
          },
          "git_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Git Url",
            "description": "Remote git repository URL"
          },
          "created_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created At",
            "description": "Used to disambiguate projects with the same name"
          }
        },
        "type": "object",
        "required": [
          "id",
          "source_type"
        ],
        "title": "ProjectSummary"
      },
      "ProjectSummaryWithGitUrl": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          },
          "source_type": {
            "type": "string",
            "title": "Source Type"
          },
          "git_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Git Url",
            "description": "Remote git repository URL; used as push target"
          },
          "created_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "source_type"
        ],
        "title": "ProjectSummaryWithGitUrl"
      },
      "TaskStatus": {
        "type": "string",
        "enum": [
          "pending",
          "aborted",
          "in_progress",
          "completed",
          "failed"
        ],
        "title": "TaskStatus"
      },
      "ProjectType": {
        "type": "string",
        "enum": [
          "new",
          "existing"
        ],
        "title": "ProjectType"
      },
      "TaskResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "project": {
            "$ref": "#/components/schemas/ProjectSummary"
          },
          "agent": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/AgentSummary"
              },
              {
                "type": "null"
              }
            ],
            "title": "Agent",
            "description": "Null for legacy tasks that predate the agent registry"
          },
          "requirements": {
            "type": "string",
            "title": "Requirements"
          },
          "status": {
            "$ref": "#/components/schemas/TaskStatus"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          }
        },
        "type": "object",
        "required": [
          "id",
          "project",
          "requirements",
          "status",
          "created_at",
          "updated_at"
        ],
        "title": "TaskResponse"
      },
      "TaskDetailResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "project": {
            "$ref": "#/components/schemas/ProjectSummaryWithGitUrl"
          },
          "agent": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/AgentSummary"
              },
              {
                "type": "null"
              }
            ],
            "title": "Agent",
            "description": "Null for legacy tasks that predate the agent registry"
          },
          "requirements": {
            "type": "string",
            "title": "Requirements"
          },
          "status": {
            "$ref": "#/components/schemas/TaskStatus"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "started_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "completed_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          },
          "work_directory_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Work Directory Path",
            "description": "Absolute path of the on-disk working directory; null until worker claims the task"
          },
          "elapsed_seconds": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Elapsed Seconds",
            "description": "Seconds elapsed since started_at; non-null only when status is in_progress"
          },
          "branch": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Branch",
            "default": null
          }
        },
        "type": "object",
        "required": [
          "id",
          "project",
          "requirements",
          "status",
          "created_at",
          "updated_at"
        ],
        "title": "TaskDetailResponse"
      },
      "PushResponse": {
        "properties": {
          "branch_name": {
            "type": "string",
            "title": "Branch Name",
            "description": "Name of the git branch created and pushed to the remote",
            "example": "task/a1b2c3d4"
          },
          "remote_url": {
            "type": "string",
            "title": "Remote Url",
            "description": "The remote git URL that was pushed to"
          },
          "pushed_at": {
            "type": "string",
            "format": "date-time",
            "title": "Pushed At",
            "description": "UTC timestamp of the successful push"
          }
        },
        "type": "object",
        "required": [
          "branch_name",
          "remote_url",
          "pushed_at"
        ],
        "title": "PushResponse"
      },
      "ErrorResponse": {
        "properties": {
          "detail": {
            "type": "string",
            "title": "Detail"
          }
        },
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "ErrorResponse"
      },
      "CreateTaskRequest": {
        "properties": {
          "project_type": {
            "$ref": "#/components/schemas/ProjectType"
          },
          "project_name": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Project Name",
            "description": "Required when project_type is \"new\". Not required to be unique."
          },
          "agent_id": {
            "type": "string",
            "format": "uuid",
            "title": "Agent Id",
            "description": "ID of the agent from the agent registry. Determines which agent library executes the task."
          },
          "git_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Git Url",
            "description": "Remote git repository URL. Required when project_type is 'existing'. Optional for new projects."
          },
          "requirements": {
            "type": "string",
            "minLength": 1,
            "title": "Requirements"
          },
          "branch": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 255
              },
              {
                "type": "null"
              }
            ],
            "title": "Branch",
            "description": "Git branch to clone and check out. Created from default branch if it doesn't exist remotely. Null = use default branch.",
            "default": null
          }
        },
        "type": "object",
        "required": [
          "project_type",
          "agent_id",
          "requirements"
        ],
        "title": "CreateTaskRequest"
      },
      "UpdateTaskRequest": {
        "properties": {
          "status": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TaskStatus"
              },
              {
                "type": "null"
              }
            ],
            "title": "Status"
          },
          "project_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Project Id"
          },
          "requirements": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Requirements"
          }
        },
        "type": "object",
        "title": "UpdateTaskRequest"
      },
      "SettingsResponse": {
        "properties": {
          "settings": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "title": "Settings"
          }
        },
        "type": "object",
        "required": [
          "settings"
        ],
        "title": "SettingsResponse"
      },
      "UpdateSettingsRequest": {
        "properties": {
          "settings": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "title": "Settings"
          }
        },
        "type": "object",
        "required": [
          "settings"
        ],
        "title": "UpdateSettingsRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
